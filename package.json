{
  "name": "sterm",
  "version": "0.2.1",
  "description": "An AI agent control plane with real terminals and resumable Pi sessions",
  "author": "S-Block Technologies",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sblocktechnologies/s-term.git"
  },
  "homepage": "https://github.com/sblocktechnologies/s-term#readme",
  "bugs": {
    "url": "https://github.com/sblocktechnologies/s-term/issues"
  },
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "tsc -b && vite build",
    "start": "electron .",
    "test": "node --test test/*.test.cjs",
    "integrations:status": "node scripts/integrations.mjs status",
    "integrations:install": "node scripts/integrations.mjs install",
    "integrations:uninstall": "node scripts/integrations.mjs uninstall",
    "integrations:doctor": "node scripts/integrations.mjs doctor",
    "package": "npm run build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "overrides": {
    "shell-quote": "1.10.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.sblock.sterm",
    "productName": "S-Term",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "integrations",
        "to": "integrations"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": "dmg"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis"
    },
    "linux": {
      "category": "Development",
      "icon": "build/icon.png",
      "target": "AppImage"
    }
  }
}
